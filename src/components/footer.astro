---
import { Icon } from 'astro-icon/components';
import localData from '../data/home.json';

---

<section id="contact" class="section-container">
  <div class="container mx-auto">
    <div class="space-y-12">

      <!-- /* FOOTER */ -->
      <div class="contact-footer opacity-0 pt-20 border-t border-white/5">
        <div class="flex flex-col md:flex-row justify-between items-center">
          <p class="text-subtext text-sm font-body order-2 md:order-1">
            {localData.name} © 2026
          </p>
        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  /* Header & Footer Initial State */
  .contact-header,
  .contact-footer {
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Cards Initial State */
  .contact-card {
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Shared Revealed State */
  .contact-header.reveal,
  .contact-card.reveal,
  .contact-footer.reveal {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  const revealContact = () => {
    const header = document.querySelector('.contact-header');
    const footer = document.querySelector('.contact-footer');
    const cards = document.querySelectorAll('.contact-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;

          if (target.classList.contains('contact-card')) {
            const index = Array.from(cards).indexOf(target);
            // Stagger effect for the 4-column grid
            setTimeout(() => {
              target.classList.add('reveal');
            }, (index % 4) * 150);
          } else {
            // Header and Footer reveal immediately
            target.classList.add('reveal');
          }
          
          observer.unobserve(target);
        }
      });
    }, { 
      threshold: 0.15,
      rootMargin: '0px 0px -10px 0px'
    });

    if (header) observer.observe(header);
    if (footer) observer.observe(footer);
    cards.forEach(card => observer.observe(card));
  }
  
  // Runs on initial load
  window.addEventListener('load', revealContact);
  
  // Support for Astro View Transitions
  document.addEventListener('astro:after-swap', revealContact);
</script>